---
import type { ProjectProps } from '../data/projects.ts'
import TechnologyRibbon from './TechnologyRibbon.astro'

const {
    title,
    summary,
    description,
    fromDate,
    toDate,
    categories = [],
    technologies = [],
    repoUrl,
    postUrl,
    liveUrl,
    coverMedia,
    media = [],
} = Astro.props as ProjectProps

const indices = Array.isArray(coverMedia) ? coverMedia : [coverMedia]
const validIndices = indices.filter((i) => i >= 0 && i < media.length)
const isCarousel = validIndices.length > 1
---

<div class="project-card group/card" data-card>
    {
        validIndices.length > 0 && (
            <div class="absolute top-0 bottom-0 right-0 pointer-events-none z-0 overflow-hidden transition-[width] duration-300 ease-out" data-carousel>
                <div class="relative h-full">
                    {validIndices.map((idx, slideIdx) => {
                        const item = media[idx]
                        const src = typeof item.src === 'string' ? item.src : (item.src?.src ?? '')
                        const wrapClass = `${slideIdx === 0 ? 'relative' : 'absolute inset-0 opacity-0'} h-full pointer-events-none transition-opacity duration-300`
                        const mediaClass = 'h-full w-auto select-none pointer-events-none'
                        return (
                            <div class={wrapClass} data-slide>
                                {item.type === 'image' ? (
                                    <img src={src} alt={item.alt ?? title} class={mediaClass} />
                                ) : (
                                    <video
                                        src={src}
                                        class={mediaClass}
                                        autoplay
                                        muted
                                        loop
                                        playsinline
                                    />
                                )}
                            </div>
                        )
                    })}
                </div>

                <div id="img-gradient-overlay" aria-hidden="true" />
            </div>
        )
    }

    {
        isCarousel && (
            <>
                <button
                    class="carousel-prev pointer-events-auto absolute z-10
                           right-10 top-1/2 -translate-y-1/2
                           w-7 h-7 rounded-lg bg-black/50 text-white text-lg leading-none
                           flex items-center justify-center
                           opacity-70 group-hover/card:opacity-100 hover:bg-black/75
                           transition-all duration-100 ease-out"
                    aria-label="Previous image"
                >
                    ‹
                </button>
                <button
                    class="carousel-next pointer-events-auto absolute z-10
                           right-2 top-1/2 -translate-y-1/2
                           w-7 h-7 rounded-lg bg-black/50 text-white text-lg leading-none
                           flex items-center justify-center
                           opacity-70 group-hover/card:opacity-100 hover:bg-black/75
                           transition-all duration-100 ease-out"
                    aria-label="Next image"
                >
                    ›
                </button>
            </>
        )
    }

    <div id="content">
        <div
            class="group-hover/card:text-on-surface text-on-surface/85 transition-all duration-100 ease-out"
        >
            <h4 class="font-medium text-xl sm:text-3xl lg:text-2xl">{title}</h4>
            <p class="mt-0.5 sm:mt-1.5 lg:mt-0.5 sm:w-2/3 text-xs sm:text-base lg:text-sm">
                {summary}
            </p>
        </div>
        <TechnologyRibbon technologies={technologies} />
    </div>

    <div id="urls">
        {
            repoUrl && (
                <a href={repoUrl} target="_blank" class="bg-white text-neutral-900">
                    {'Code </>'}
                </a>
            )
        }
        {
            postUrl && (
                <a href={postUrl} target="_blank" class="bg-white text-blue-800">
                    {'Post 📝'}
                </a>
            )
        }
        {
            liveUrl && (
                <a href={liveUrl} target="_blank" class="bg-white text-red-800">
                    {'Live 🚀'}
                </a>
            )
        }
    </div>
</div>

<script>
    document.querySelectorAll('[data-card]').forEach((card) => {
        const carousel = card.querySelector('[data-carousel]') as HTMLElement | null
        const slides = Array.from(card.querySelectorAll('[data-slide]')) as HTMLElement[]
        if (slides.length <= 1) return

        let current = 0

        // Lock initial width so CSS transition has an explicit value to animate from
        if (carousel) carousel.style.width = carousel.offsetWidth + 'px'

        const naturalDisplayWidth = (slide: HTMLElement) => {
            const img = slide.querySelector('img') as HTMLImageElement | null
            if (!img || !carousel || !img.naturalWidth || !img.naturalHeight) return null
            return carousel.offsetHeight * img.naturalWidth / img.naturalHeight
        }

        const showSlide = (idx: number) => {
            const prev = slides[current]
            current = ((idx % slides.length) + slides.length) % slides.length
            const next = slides[current]

            prev.classList.add('opacity-0', 'absolute', 'inset-0')
            prev.classList.remove('relative')

            next.classList.remove('opacity-0', 'absolute', 'inset-0')
            next.classList.add('relative')

            const w = naturalDisplayWidth(next)
            if (w && carousel) carousel.style.width = w + 'px'
        }

        card.querySelector('.carousel-prev')?.addEventListener('click', () => showSlide(current - 1))
        card.querySelector('.carousel-next')?.addEventListener('click', () => showSlide(current + 1))
    })
</script>
