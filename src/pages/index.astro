---
import Layout from '../layouts/Layout.astro'
import ContactButton from '../components/ContactButton.astro'
import TabNavigator from '../components/TabNavigator.astro'

import profilePic from '../assets/me.jpg'

import { contacts } from '../data/contacts'
---

<Layout>
    <div
        class="w-full px-4 sm:px-12 lg:px-10 py-[5vh] flex flex-col lg:flex-row gap-8 justify-center overflow-x-hidden"
    >
        <div class="lg:basis-[34.5rem] flex flex-col items-stretch gap-5">
            <div class="flex flex-col sm:flex-row lg:flex-col gap-3.5 sm:gap-5 lg:gap-3.5">
                <div
                    class="flex-2 flex gap-3 items-center justify-start p-3 rounded-3xl bg-surface"
                >
                    <div class="w-21 sm:w-23 aspect-[7/8] bg-white rounded-2xl overflow-hidden">
                        <img
                            src={profilePic.src}
                            alt="Portrait of Alexis Bollack"
                            class="w-full h-full object-cover"
                        />
                    </div>
                    <div
                        class="flex-5 lg:flex-[1.6] h-full flex flex-col justify-center gap-x-1.5 lg:flex-wrap min-w-0 w-full
                            text-[30px] sm:text-[32px] leading-[0.92] font-medium"
                    >
                        <span class="break-words whitespace-normal text-base sm:text-lg mb-1"
                            >👋 Hello, I'm</span
                        >
                        <span class="break-words whitespace-normal text-accent text-glow-s">
                            Alexis
                        </span>
                        <span class="whitespace-normal text-accent text-glow-s">
                            Bollack
                        </span>
                    </div>
                </div>

                <div
                    class="-m-3 p-3 flex-1 flex flex-row sm:flex-col lg:flex-row flex-wrap justify-start sm:justify-center lg:justify-start gap-2 font-regular overflow-clip"
                >
                    {contacts.map((contact) => <ContactButton {...contact} />)}
                </div>
            </div>
            <div class="flex flex-col gap-3 overflow-auto max-h-[40vh] lg:max-h-full">
                <p>
                    Hi! I'm Alexis, a Robotics Engineering student pursuing a double degree between
                    EPFL and École Centrale de Nantes.
                </p>
                <p>
                    I'm interested in autonomous systems and control methods. Wether it's new
                    approaches with Reinforcement Learning or traditional ones. I like to
                    balance between the opportunities offered by simulation and implementing my ideas
                    into real products.
                </p>
                <p>
                    You can find evidence of this balance on the project section with my experiences ranging from ROS2 control to RL agent
                    training on multiple environments and engines.
                </p>
                <p>
                    Outside of robotics, I love to play sports. I started with <button id="tt-easter-egg" aria-label="Watch a table tennis clip">table tennis</button>,
                    this early passion propagated to all racket sports! I'm also a volleyball player
                    and half-marathon runner. Overall, I would say that playing sports is my favorite
                    hobby!!
                </p>
                <div id="tt-video-container">
                    <div id="tt-video-inner">
                        <div id="tt-video-box">
                            <div id="tt-video-header">
                                <span>🏓 back when i was good</span>
                                <button id="tt-close" aria-label="Close">✕</button>
                            </div>
                            <div id="tt-video-wrapper">
                                <iframe
                                    id="tt-iframe"
                                    src=""
                                    title="Table tennis clip"
                                    frameborder="0"
                                    allow="autoplay; encrypted-media"
                                    allowfullscreen></iframe>
                            </div>
                        </div>
                    </div>
                </div>
                <p>
                    I'm actively seeking a <strong>6-month industry internship in robotics starting
                    September 2026</strong>. If you're working on legged robots, embodied AI, or
                    autonomous systems, I'd love to connect! Feel free to reach out!
                </p>
            </div>
        </div>
        <div class="max-h-[72vh] sm:max-h-[84vh] lg:max-h-full basis-3xl flex flex-col">
            <TabNavigator />
        </div>
    </div>

</Layout>

<style>
    #tt-easter-egg {
        background: none;
        border: none;
        padding: 0;
        font: inherit;
        color: var(--accent);
        cursor: pointer;
        text-decoration: underline dotted;
        text-decoration-color: color-mix(in oklch, var(--accent) 50%, transparent);
        text-underline-offset: 3px;
        transition: text-shadow 0.1s ease;
    }
    #tt-easter-egg:hover {
        text-shadow: 0 0 6px rgba(var(--glow-rgb), 0.4);
        text-decoration-color: var(--accent);
    }

    /* Collapse/expand using grid trick so no fixed height needed */
    #tt-video-container {
        display: grid;
        grid-template-rows: 0fr;
        transition: grid-template-rows 0.35s cubic-bezier(0.4, 0, 0.2, 1);
    }
    #tt-video-container.open {
        grid-template-rows: 1fr;
    }

    #tt-video-inner {
        overflow: hidden;
    }

    #tt-video-box {
        border-radius: 0.875rem;
        overflow: hidden;
        background: var(--surface);
        box-shadow:
            0 0 0 1px oklch(100% 0 0 / 8%),
            0 0 16px rgba(var(--glow-rgb), 0.2);
        margin-bottom: 0.25rem;
        transform: translateY(-6px);
        opacity: 0;
        transition:
            transform 0.35s cubic-bezier(0.4, 0, 0.2, 1),
            opacity 0.3s ease;
    }
    #tt-video-container.open #tt-video-box {
        transform: translateY(0);
        opacity: 1;
    }

    #tt-video-header {
        display: flex;
        align-items: center;
        justify-content: space-between;
        padding: 0.5rem 0.6rem 0.5rem 0.875rem;
        font-size: 0.8rem;
        font-weight: 500;
        color: var(--accent);
        background: oklch(100% 0 0 / 4%);
        border-bottom: 1px solid oklch(100% 0 0 / 6%);
    }

    #tt-close {
        background: none;
        border: none;
        color: var(--on-surface);
        opacity: 0.5;
        cursor: pointer;
        font-size: 0.9rem;
        padding: 0.15rem 0.35rem;
        border-radius: 0.35rem;
        transition: opacity 0.1s, background 0.1s;
    }
    #tt-close:hover {
        opacity: 1;
        background: oklch(100% 0 0 / 8%);
    }

    #tt-video-wrapper {
        position: relative;
        aspect-ratio: 16 / 9;
        background: #000;
    }
    #tt-iframe {
        position: absolute;
        inset: 0;
        width: 100%;
        height: 100%;
    }
</style>

<script>
    const container = document.getElementById('tt-video-container')!
    const closeBtn = document.getElementById('tt-close')!
    const iframe = document.getElementById('tt-iframe') as HTMLIFrameElement
    const trigger = document.getElementById('tt-easter-egg')!

    // Preload the player immediately — hidden in the collapsed container
    iframe.src = 'https://www.youtube.com/embed/82llbbMgHbw?start=310&end=315&autoplay=0&rel=0&enablejsapi=1'

    function ytCmd(cmd: string, args: unknown[] = []) {
        iframe.contentWindow?.postMessage(
            JSON.stringify({ event: 'command', func: cmd, args }),
            '*'
        )
    }

    function open() {
        container.classList.add('open')
        ytCmd('playVideo')
    }

    function close() {
        container.classList.remove('open')
        ytCmd('pauseVideo')
        // seek back to start so next open plays from the right spot
        setTimeout(() => ytCmd('seekTo', [310, true]), 350)
    }

    trigger.addEventListener('click', () => {
        container.classList.contains('open') ? close() : open()
    })
    closeBtn.addEventListener('click', close)
    document.addEventListener('keydown', (e) => {
        if (e.key === 'Escape') close()
    })
</script>
